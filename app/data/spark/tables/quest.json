    {
      "role": "plain",
      "die": 24,
      "rows": [
        { "text": "но за ним охотятся другие" },
        { "text": "до наступления рассвета" },
        { "text": "не привлекая внимания стражи" },
        { "text": "пока хозяин не хватился" },
